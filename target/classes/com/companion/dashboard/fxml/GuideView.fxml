<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="20.0" alignment="TOP_LEFT" style="-fx-padding: 30;" styleClass="content-background" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="com.companion.dashboard.controllers.GuideController">

    <VBox spacing="5.0">
        <Label text="🔮 AI Game Guide" style="-fx-text-fill: #ffffff; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Label text="Consult the grimoire for crafting recipes, optimal farm layouts, or item locations." style="-fx-text-fill: #a0a0aa; -fx-font-size: 14px;"/>
    </VBox>

    <TextArea fx:id="txtOutput" VBox.vgrow="ALWAYS" editable="false" wrapText="true"
              text="Ask a question below to consult the grimoire..."
              style="-fx-control-inner-background: #1e1e24; -fx-text-fill: #e4e4e7; -fx-font-size: 14px; -fx-background-color: transparent; -fx-border-color: #27272a; -fx-border-radius: 5; -fx-background-radius: 5;"/>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="txtInput" HBox.hgrow="ALWAYS" promptText="e.g., What is the most efficient way to farm ender pearls?"
                   style="-fx-background-color: #1e1e24; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #71717a; -fx-padding: 12; -fx-background-radius: 5; -fx-border-color: #27272a; -fx-border-radius: 5; -fx-font-size: 14px;"/>

        <Button fx:id="btnSend" text="Consult" onAction="#handleSendQuery" minWidth="100.0"
                style="-fx-background-color: #6366f1; -fx-text-fill: #ffffff; -fx-padding: 12 20 12 20; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
    </HBox>

</VBox>