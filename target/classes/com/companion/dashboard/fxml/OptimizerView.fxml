<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox spacing="20.0" alignment="TOP_LEFT" style="-fx-padding: 30;" styleClass="content-background" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="com.companion.dashboard.controllers.OptimizerController">

    <VBox spacing="5.0">
        <Label text="⚙️ System Optimizer" style="-fx-text-fill: #ffffff; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Label text="Generate custom JVM launch arguments to eliminate lag spikes." style="-fx-text-fill: #a0a0aa; -fx-font-size: 14px;"/>
    </VBox>

    <VBox spacing="15.0" style="-fx-background-color: #1e1e24; -fx-padding: 20; -fx-background-radius: 8;">

        <HBox spacing="20.0" alignment="CENTER_LEFT">
            <Label text="Total System RAM:" style="-fx-text-fill: #e4e4e7; -fx-font-size: 14px; -fx-pref-width: 150;"/>
            <ComboBox fx:id="ramCombo" style="-fx-background-color: #27272a; -fx-text-fill: white;">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="8 GB"/>
                        <String fx:value="16 GB"/>
                        <String fx:value="32 GB"/>
                        <String fx:value="64 GB"/>
                    </FXCollections>
                </items>
                <value>
                    <String fx:value="16 GB"/>
                </value>
            </ComboBox>
        </HBox>

        <VBox spacing="10.0">
            <Label text="Modpack Intensity (Number of Mods):" style="-fx-text-fill: #e4e4e7; -fx-font-size: 14px;"/>
            <Slider fx:id="modSlider" min="0" max="400" value="150" showTickLabels="true" showTickMarks="true" majorTickUnit="100"/>
        </VBox>

        <Button fx:id="btnOptimize" text="Generate Launch Profile" onAction="#handleOptimize"
                style="-fx-background-color: #10b981; -fx-text-fill: #ffffff; -fx-padding: 10 20 10 20; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
    </VBox>

    <TextArea fx:id="txtOutput" VBox.vgrow="ALWAYS" editable="false" wrapText="true"
              text="Your optimized launch arguments will appear here..."
              style="-fx-control-inner-background: #121214; -fx-text-fill: #34d399; -fx-font-family: 'Consolas', monospace; -fx-font-size: 14px; -fx-border-color: #27272a; -fx-border-radius: 5; -fx-background-radius: 5;"/>

</VBox>